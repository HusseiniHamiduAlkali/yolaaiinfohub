# ============================================================
# YOLA AI INFO HUB - PRODUCTION ENVIRONMENT VARIABLES
# ============================================================
# This file contains production secrets and should NEVER be committed to version control
# Copy .env.example to .env.production and fill in actual production values

# ============================================================
# NODE ENVIRONMENT
# ============================================================
NODE_ENV=production
PORT=4000

# ============================================================
# DATABASE
# ============================================================
# Use MongoDB Atlas or hosted MongoDB URL in production
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/yola-ai-info-hub?retryWrites=true&w=majority

# ============================================================
# AI PROVIDER API KEYS
# ============================================================

# OpenAI API Keys (for GPT-5.5 and GPT-5-mini models)
# Generate keys: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini API Keys (for Gemini 2.5 Flash and Pro models)
# Generate keys: https://ai.google.dev/
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# MAPS & LOCATION APIs
# ============================================================

# Google Maps API Key
MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# TomTom Maps API Key
TOMTOM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# EMAIL CONFIGURATION
# ============================================================

# Production email service (e.g., SendGrid, AWS SES, or your SMTP server)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASS=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yolaaiinfohub.com

# ============================================================
# SESSION & SECURITY
# ============================================================

# IMPORTANT: Change this to a long, random string in production
SESSION_SECRET=your-long-random-secret-key-at-least-32-characters

# ============================================================
# FRONTEND URLS
# ============================================================

# Production frontend URL
FRONTEND_URL=https://yolaaiinfohub.netlify.app
FRONT_END_URL=https://yolaaiinfohub.netlify.app

# ============================================================
# DEBUG & LOGGING
# ============================================================

# Disable debug features in production
DEBUG_RESET=false
SUPPRESS_RESET_LOG=true
