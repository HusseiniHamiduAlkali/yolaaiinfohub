  function getStoredLanguage(){
    const l = localStorage.getItem(STORAGE_KEY);
    return l || defaultLang;
  }

  function setLanguage(lang){
    if (!translations[lang]) lang = defaultLang;
    localStorage.setItem(STORAGE_KEY, lang);
    // Trigger full app translation
    applyTranslations(document);
    // set document lang attribute
    try{ document.documentElement.lang = lang; }catch(e){}
    // Dispatch custom event so components can react to language change
    try{ window.dispatchEvent(new CustomEvent('languageChanged', { detail: { language: lang } })); }catch(e){}
  }

  function getCurrentLanguage(){
    return getStoredLanguage();
  }

  function t(key){
    const lang = getStoredLanguage();
    const dict = translations[lang] || translations[defaultLang];
    return dict[key] || translations[defaultLang][key] || key;
  }

  function applyTranslations(root=document){
    // Translate elements with data-i18n
    const nodes = root.querySelectorAll('[data-i18n]');
    nodes.forEach(n => {
      const key = n.getAttribute('data-i18n');
      if (!key) return;
      const text = t(key);
      if (n.placeholder !== undefined && n.hasAttribute('data-i18n-placeholder')){
        n.placeholder = text;
      } else if (n.tagName === 'INPUT' || n.tagName === 'TEXTAREA'){
        // set value for inputs with data-i18n-value
        if (n.hasAttribute('data-i18n-value')) n.value = text;
      } else {
        n.textContent = text;
      }
    });
  }

  // AI localization helper - prepend an instruction
  function localizeAIRequest(prompt){
    const lang = getStoredLanguage();
    const map = {
      en: 'Answer in English: ',
      ar: 'أجب باللغة العربية: ',
      fr: 'Répondez en français: ',
      ha: 'Amsa a cikin Hausa: ',
      ff: 'Hollu e Fulfulde: '
    };
    return (map[lang] || map.en) + prompt;
  }

  // Expose API
  window.i18n = {
    t, setLanguage, getCurrentLanguage, applyTranslations
  };
  window.getCurrentLanguage = getCurrentLanguage;
  window.setAppLanguage = setLanguage;
  window.t = t;
  window.localizeAIRequest = localizeAIRequest;
  window.applyTranslations = applyTranslations;

  // Setup MutationObserver to auto-translate dynamically added content
  function setupAutoTranslate(){
    const observer = new MutationObserver((mutations) => {
      // Check if any new elements with data-i18n were added
      let hasI18nNodes = false;
      mutations.forEach(m => {
        if (m.addedNodes.length) {
          m.addedNodes.forEach(node => {
            if (node.nodeType === 1 && (node.hasAttribute && node.hasAttribute('data-i18n') || (node.querySelectorAll && node.querySelectorAll('[data-i18n]').length > 0))) {
              hasI18nNodes = true;
            }
          });
        }
      });
      // Debounce and apply translations if found
      if (hasI18nNodes) {
        clearTimeout(window.i18nDebounceTimer);
        window.i18nDebounceTimer = setTimeout(() => {
          applyTranslations(document);
        }, 100);
      }
    });
    
    observer.observe(document.body, {
      childList: true,
      subtree: true,
      attributes: false,
      characterData: false
    });
  }

  // Apply translations at load
  if (document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', () => {
      applyTranslations(document);
      setupAutoTranslate();
    });
  } else {
    applyTranslations(document);
    setupAutoTranslate();
  }
})();
